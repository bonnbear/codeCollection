}

/* 关键：未选中的项置灰 */
.legend-item.is-disabled {
  color: #aaa;
  opacity: 0.55;
}
.legend-item.is-disabled .dot {
  /* 颜色已经在模板里改成了灰色，这里再加一点视觉弱化 */
  box-shadow: none;
  filter: grayscale(1);
}

.dot {
  width: 12px; height: 12px; border-radius: 2px; display: inline-block;
