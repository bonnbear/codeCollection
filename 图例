# 抽成 `LegendFilter` 子组件 + 父组件按状态调接口

设计思路：

- **子组件**只负责图例 UI、维护选中状态、置灰样式，**不关心业务**。
- 通过 `v-model` 把选中数组双向同步给父组件。
- 通过 `@change` 事件把"语义化的过滤状态"抛给父组件（`mode: 'all' | 'partial'`、`selected`），父组件根据这个去拼接接口参数、调接口。

---

## 子组件 `LegendFilter.vue`

```vue
<!-- components/LegendFilter.vue -->
<template>
  <div class="legend">
    <label
      v-for="item in legends"
      :key="item.key"
      class="legend-item"
      :class="{ 'is-disabled': isDimmed(item.key) }"
    >
      <input
        type="checkbox"
        :value="item.key"
        :checked="modelValue.includes(item.key)"
        @change="onToggle(item.key, $event.target.checked)"
      />
      <span
        class="dot"
        :style="{ background: isDimmed(item.key) ? '#ccc' : item.color }"
      ></span>
      {{ item.label }}
    </label>

    <button class="btn" @click="selectAll">全选</button>
    <button class="btn" @click="clearAll">全不选</button>

    <span class="tip">
      <b>{{ modeText }}</b>（{{ modelValue.length }} / {{ legends.length }}）
    </span>
  </div>
</template>

<script setup>
import { computed } from 'vue'

const props = defineProps({
  // 图例配置：[{ key, label, color }]
  legends: {
    type: Array,
    required: true,
  },
  // v-model 绑定的选中 key 数组
  modelValue: {
    type: Array,
    default: () => [],
  },
})

const emit = defineEmits(['update:modelValue', 'change'])

// 是否处于部分选中
const isPartial = computed(() => {
  const len = props.modelValue.length
  return len > 0 && len < props.legends.length
})

// 全选/全不选都视为 'all'，部分选中为 'partial'
const mode = computed(() => (isPartial.value ? 'partial' : 'all'))

const modeText = computed(() => {
  const len = props.modelValue.length
  if (len === 0) return '全不选 → 全部'
  if (len === props.legends.length) return '全选 → 全部'
  return '部分选中'
})

function isDimmed(key) {
  return isPartial.value && !props.modelValue.includes(key)
}

// 统一的更新出口：同时更新 v-model 和触发 change 事件
function update(next) {
  emit('update:modelValue', next)
  emit('change', {
    mode: next.length === 0 || next.length === props.legends.length
      ? 'all'
      : 'partial',
    selected: next,
  })
}

function onToggle(key, checked) {
  const set = new Set(props.modelValue)
  checked ? set.add(key) : set.delete(key)
  // 保持原顺序
  update(props.legends.map(l => l.key).filter(k => set.has(k)))
}

function selectAll() {
  update(props.legends.map(l => l.key))
}
function clearAll() {
  update([])
}
</script>

