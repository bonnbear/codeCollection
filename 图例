  // 部分选中：传选中的 key 列表
  return {
    types: selected,            // 数组
    // 或后端要逗号分隔: types: selected.join(','),
  }
}

// 子组件的 change 事件
function onLegendChange(state) {
  // state = { mode: 'all' | 'partial', selected: [...] }
  fetchList(buildParams(state))
}

// 初始化：默认全部
onMounted(() => {
  fetchList(buildParams({ mode: 'all', selected: [] }))
})

// ====== 工具 ======
