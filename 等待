## `src/components/IframeChild.vue`

```vue
<template>
  <iframe
    v-if="visible"
    :src="src"
    :class="iframeClass"
    @load="onLoad"
  />
</template>

<script setup>
import { ref, watch } from 'vue'
import { useRoute } from 'vue-router'
import {
  needIframeGateByHref,
  ensureGate,
  waitGate,
  notifyFirstIframeLoaded,
  isGateOpened
} from '@/utils/iframeGate'

const props = defineProps({
  src: { type: String, required: true },
  first: { type: Boolean, default: false },
  minWait: { type: Number, default: 2000 },
  fallback: { type: Number, default: 10000 },
  iframeClass: { type: String, default: '' }
})

const route = useRoute()
const visible = ref(false)

async function init() {
  visible.value = false

  const href = window.location.href
  const needGate = needIframeGateByHref(href)

  if (!needGate) {
    visible.value = true
    return
  }

  ensureGate(href, {
    minWait: props.minWait,
    fallback: props.fallback
  })

  if (props.first) {
    visible.value = true
    return
  }

  if (isGateOpened()) {
    visible.value = true
    return
  }

  await waitGate()
  visible.value = true
}

function onLoad() {
  if (props.first && needIframeGateByHref(window.location.href)) {
    notifyFirstIframeLoaded()
  }
}

watch(() => route.fullPath, init, { immediate: true })
</script>
```

