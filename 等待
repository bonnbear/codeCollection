# 2）组件文件

## `src/components/IframeChild.vue`

```vue
<template>
  <!--
    visible 为 true 才真正创建 iframe
    这样没放行前不会提前发请求
  -->
  <iframe
    v-if="visible"
    :src="src"
    :class="iframeClass"
    @load="onLoad"
  />
</template>

<script setup>
import { ref, watch } from 'vue'
import { useRoute } from 'vue-router'
import {
  needIframeGateByHref,
  ensureGate,
  waitGate,
  notifyFirstIframeLoaded,
  isGateOpened
} from '@/utils/iframeGate'

// 组件参数
const props = defineProps({
  // iframe 地址
  src: {
    type: String,
    required: true
  },

  // 是否是第一个 iframe
  // 第一个会先加载
  first: {
    type: Boolean,
    default: false
  },

  // 至少等待多久，默认 2 秒
  minWait: {
    type: Number,
    default: 2000
  },

  // 超时兜底多久，默认 10 秒
  fallback: {
    type: Number,
    default: 10000
  },

  // 外部自定义 iframe class
  iframeClass: {
    type: String,
    default: ''
  }
})

const route = useRoute()

// 控制 iframe 是否真正渲染
const visible = ref(false)

/**
 * 初始化当前 iframe 的显示逻辑
 */
async function init() {
  // 先隐藏，避免旧状态残留
  visible.value = false

  // 当前页面地址
  const href = window.location.href

  // 判断当前页面是否需要 gate
  const needGate = needIframeGateByHref(href)

  // 不需要 gate，直接显示
  if (!needGate) {
    visible.value = true
    return
  }

  // 需要 gate，就初始化一下全局 gate
  ensureGate(href, {
    minWait: props.minWait,
    fallback: props.fallback
  })

  // 第一个 iframe 直接显示
  if (props.first) {
    visible.value = true
    return
  }

  // 如果已经放行过了，也直接显示
  if (isGateOpened()) {
    visible.value = true
    return
  }

  // 其他 iframe 等待 gate 放行
  await waitGate()
  visible.value = true
}

/**
 * iframe load 完成事件
 */
function onLoad() {
  // 只有“当前是第一个 iframe”并且“当前页面命中规则”时
  // 才通知全局 gate：第一个 iframe 已经好了
  if (props.first && needIframeGateByHref(window.location.href)) {
    notifyFirstIframeLoaded()
  }
}

// 监听路由变化
// 页面切换时重新执行一次
watch(
  () => route.fullPath,
  () => {
    init()
  },
  { immediate: true }
)
</script>
```

