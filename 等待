# 1）合并后的工具文件

## `src/utils/iframeGate.js`

```js
// =========================
// 哪些页面需要启用 iframe gate
// 当前页面 href 只要包含下面任意一个字符串，就会启用
// 你把这里改成你自己的页面路径即可
// =========================
const HIT_LIST = [
  '/xxx/page1',
  '/xxx/page2',
  '/xxx/page3'
]

/**
 * 根据当前页面 href 判断是否需要启用 gate
 * @param {string} href
 * @returns {boolean}
 */
export function needIframeGateByHref(href = window.location.href) {
  return HIT_LIST.some((item) => href.includes(item))
}

/**
 * 创建一个 deferred promise
 * 作用：
 * 1. 其他 iframe 可以 await 这个 promise
 * 2. 第一个 iframe load 后可以手动 resolve
 */
function createDeferred() {
  let resolve

  const promise = new Promise((res) => {
    resolve = res
  })

  return { promise, resolve }
}

// gate 是否已经放行
let opened = false

// 当前 gate 是否已经初始化过
let started = false

// 当前页面标识，这里直接用 href 区分
let currentKey = ''

// 第一个 iframe 是否已经 load 完成
let firstLoaded = false

// 最少等待时间是否已到
let minWaitDone = false

// 当前 promise 对象
let deferred = createDeferred()

// 最少等待时间的定时器
let minTimer = null

// 超时兜底定时器
let fallbackTimer = null

/**
 * 清理定时器
 */
function clearTimers() {
  if (minTimer) {
    clearTimeout(minTimer)
    minTimer = null
  }

  if (fallbackTimer) {
    clearTimeout(fallbackTimer)
    fallbackTimer = null
  }
}

/**
 * 真正执行放行
 * 只执行一次
 */
function doOpen() {
  if (opened) return

  opened = true
  deferred.resolve()
  clearTimers()
}

/**
 * 尝试放行
 * 条件：
 * 1. 第一个 iframe 已经 load
 * 2. 最少等待时间已到
 */
function tryOpen() {
  if (firstLoaded && minWaitDone) {
    doOpen()
  }
}

/**
 * 确保 gate 已初始化
 * 同一个 href 不重复初始化
 *
 * @param {string} key 当前页面标识
 * @param {{ minWait?: number, fallback?: number }} options
 */
export function ensureGate(key = window.location.href, options = {}) {
  const { minWait = 2000, fallback = 10000 } = options

  // 同一个页面已经初始化过了，就不重复重置
  if (started && currentKey === key) {
    return
  }

  resetGate(key, { minWait, fallback })
}

/**
 * 重置 gate
 * 一般切页面时会重新初始化
 *
 * @param {string} key 当前页面标识
 * @param {{ minWait?: number, fallback?: number }} options
 */
export function resetGate(key = window.location.href, options = {}) {
  const { minWait = 2000, fallback = 10000 } = options

  clearTimers()

  opened = false
  started = true
  currentKey = key
  firstLoaded = false
  minWaitDone = false
  deferred = createDeferred()

  // 至少等 2 秒
  minTimer = setTimeout(() => {
    minWaitDone = true
    tryOpen()
  }, minWait)

  // 超时兜底
  fallbackTimer = setTimeout(() => {
    doOpen()
  }, fallback)
}

/**
 * 第一个 iframe load 完成后调用
 */
export function notifyFirstIframeLoaded() {
  firstLoaded = true
  tryOpen()
}

/**
 * 其他 iframe 等待 gate
 */
export function waitGate() {
  return opened ? Promise.resolve() : deferred.promise
}

/**
 * 当前 gate 是否已经放行
 */
export function isGateOpened() {
  return opened
}
```

