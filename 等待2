# 二、`src/components/IframeChild.vue`

```vue
<template>
  <iframe
    v-if="visible"
    :src="src"
    :class="iframeClass"
    @load="onLoad"
  />
</template>

<script setup>
import { ref, onMounted, onUnmounted } from 'vue'
import {
  needIframeGateByHref,
  ensureGate,
  registerIframe,
  unregisterIframe,
  notifyIframeLoaded,
  waitGate,
  isGateOpened
} from '@/utils/iframeGate'

const props = defineProps({
  // iframe 地址
  src: {
    type: String,
    required: true
  },

  // 自定义样式类名
  iframeClass: {
    type: String,
    default: ''
  }
})

// 控制 iframe 是否渲染
const visible = ref(false)

// 当前组件实例的唯一 id
const iframeId = `iframe_${Math.random().toString(36).slice(2)}_${Date.now()}`

// 记录 init 时是否命中 gate，供 onLoad 使用
// 避免 onLoad 时重新读 href 导致判断不准
const gateActive = ref(false)

/**
 * 初始化逻辑
 */
async function init() {
  visible.value = false
  gateActive.value = false

  const href = window.location.href
  const needGate = needIframeGateByHref(href)

  // 不需要 gate，直接显示
  if (!needGate) {
    visible.value = true
    return
  }

  // 命中 gate
  gateActive.value = true

  // 初始化当前页面的 gate（同页面只初始化一次）
  ensureGate(href)

  // 注册当前 iframe
  const { isFirst } = registerIframe(iframeId)

  // first 立即显示
  if (isFirst) {
    visible.value = true
    return
  }

  // 已经放行过了，直接显示
  if (isGateOpened()) {
    visible.value = true
    return
  }

  // 等待放行
  await waitGate()

  visible.value = true
}

/**
 * iframe 加载完成事件
 */
function onLoad() {
  if (gateActive.value) {
    notifyIframeLoaded(iframeId)
  }
}

onMounted(() => {
  init()
})

onUnmounted(() => {
  // 组件销毁时注销
  // 如果销毁的是 first 且还没放行，gate 会自动放行
  if (gateActive.value) {
    unregisterIframe(iframeId)
  }
})
</script>
```

