# 一、`src/utils/iframeGate.js`

```js
// =========================
// 哪些页面需要启用 iframe 串行控制
// 当前页面 href 包含以下任意字符串时启用
// 没命中则所有 iframe 直接加载
// =========================
const HIT_LIST = [
  '/xxx/page1',
  '/xxx/page2',
  '/xxx/page3'
]

// =========================
// 统一配置，不再由组件 props 传入
// =========================
const MIN_WAIT = 2000
const FALLBACK = 10000

/**
 * 根据 href 判断当前页面是否需要启用 gate
 * @param {string} href
 * @returns {boolean}
 */
export function needIframeGateByHref(href = window.location.href) {
  return HIT_LIST.some((item) => href.includes(item))
}

/**
 * 创建一个可手动 resolve 的 Promise
 */
function createDeferred() {
  let resolve

  const promise = new Promise((res) => {
    resolve = res
  })

  return { promise, resolve }
}

// 是否已经放行
let opened = false

// 是否已经初始化过
let started = false

// 当前页面标识
let currentKey = ''

// 当前页面内，第一个 iframe 的唯一 id
let firstIframeId = ''

// 第一个 iframe 是否已经 load 完成
let firstLoaded = false

// 最少等待时间是否完成
let minWaitDone = false

// 当前等待 promise
let deferred = createDeferred()

// 已注册的 iframe id 集合
const registeredIds = new Set()

// 定时器
let minTimer = null
let fallbackTimer = null

/**
 * 清理定时器
 */
function clearTimers() {
  if (minTimer) {
    clearTimeout(minTimer)
    minTimer = null
  }

  if (fallbackTimer) {
    clearTimeout(fallbackTimer)
    fallbackTimer = null
  }
}

/**
 * 真正放行，只执行一次
 */
function doOpen() {
  if (opened) return

  opened = true
  deferred.resolve()
  clearTimers()
}

/**
 * 尝试放行
 * 条件：first 已 load 且最少等待时间已到
 */
function tryOpen() {
  if (firstLoaded && minWaitDone) {
    doOpen()
  }
}

/**
 * 确保当前页面 gate 已初始化
 * 同一个页面不重复初始化
 *
 * @param {string} key
 */
export function ensureGate(key = window.location.href) {
  if (started && currentKey === key) {
    return
  }

  resetGate(key)
}

/**
 * 重置 gate
 *
 * @param {string} key
 */
export function resetGate(key = window.location.href) {
  clearTimers()

  opened = false
  started = true
  currentKey = key
  firstIframeId = ''
  firstLoaded = false
  minWaitDone = false
  deferred = createDeferred()
  registeredIds.clear()

  // 最少等待时间
  minTimer = setTimeout(() => {
    minWaitDone = true
    tryOpen()
  }, MIN_WAIT)

  // 超时兜底
  fallbackTimer = setTimeout(() => {
    doOpen()
  }, FALLBACK)
}

/**
 * 注册一个 iframe
 * 谁先注册，谁就是 first
 *
 * @param {string} iframeId
 * @returns {{ isFirst: boolean }}
 */
export function registerIframe(iframeId) {
  registeredIds.add(iframeId)

  // 如果还没有 first，则当前这个成为 first
  if (!firstIframeId) {
    firstIframeId = iframeId
    return { isFirst: true }
  }

  // 如果当前本来就是 first，也返回 true
  if (firstIframeId === iframeId) {
    return { isFirst: true }
  }

  return { isFirst: false }
}

/**
 * 注销一个 iframe
 * 如果注销的是 first 且还没放行，则直接放行
 *
 * @param {string} iframeId
 */
export function unregisterIframe(iframeId) {
  registeredIds.delete(iframeId)

  // 注销的不是 first，无影响
  if (iframeId !== firstIframeId) return

  // 注销的是 first，且已经放行了，无需处理
  if (opened) return

  // 注销的是 first，还没放行
  // 尝试从剩余注册列表里选一个新的 first
  if (registeredIds.size > 0) {
    // 取第一个
    const newFirst = registeredIds.values().next().value
    firstIframeId = newFirst
    // 新的 first 已经在页面上了，但它此时 visible 是 false
    // 这种情况比较复杂，直接放行最简单最稳
    doOpen()
  } else {
    // 没有其他 iframe 了，直接放行清理
    doOpen()
  }
}

/**
 * 通知：某个 iframe 已经 load
 * 只有 first 的 load 才会触发放行判断
 *
 * @param {string} iframeId
 */
export function notifyIframeLoaded(iframeId) {
  if (iframeId !== firstIframeId) return

  firstLoaded = true
  tryOpen()
}

/**
 * 等待 gate 放行
 */
export function waitGate() {
  return opened ? Promise.resolve() : deferred.promise
}

/**
 * 当前是否已经放行
 */
export function isGateOpened() {
  return opened
}

/**
 * 当前某个 iframe 是否是 first
 *
 * @param {string} iframeId
 * @returns {boolean}
 */
export function isFirstIframe(iframeId) {
  return iframeId === firstIframeId
}
