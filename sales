替换成：

/**
 * 根据指定字段，在树中查找目标节点的指定层级父节点
 *
 * @param {Object} tree - 当前年份的细分市场树根节点
 * @param {String|Number} targetValue - 要查找的目标值，可以是 id，也可以是 marketSegmentCode
 * @param {Number} level - 要返回的父节点层级
 * @param {String} matchKey - 用哪个字段匹配，默认用 id
 * @returns {Object|null} 找到的父节点；找不到返回 null
 */
function findParentAtLevel(tree, targetValue, level, matchKey = "id") {
  const path = []; // 保存从目标节点往上的父级路径
  /**
   * 递归遍历树
   *
   * @param {Object} node - 当前遍历的节点
   * @param {Number} currentLevel - 当前节点层级
   * @returns {Boolean} 是否找到目标节点
   */
  function traverse(node, currentLevel = 0) {
    // 防止 node 为空时报错
    if (!node) {
      return false;
    }
    // 当前节点命中目标
    if (String(node[matchKey]) === String(targetValue)) {
      return true;
    }
    // 如果有子节点，继续向下递归查找
    if (node.child && node.child.length > 0) {
      for (let child of node.child) {
        // 如果子节点或子孙节点命中目标
        if (traverse(child, currentLevel + 1)) {
          // 把当前节点加入路径
          path.unshift({
            node,
            level: currentLevel,
          });
          return true;
        }
      }
    }
    // 当前分支没有找到
    return false;
  }
  // 从根节点开始查找
  traverse(tree, 0);
  // 找指定层级的父节点
  const parentAtLevel = path.find((item) => item.level === level);
  // 找到则返回父节点，找不到返回 null
  return parentAtLevel ? parentAtLevel.node : null;
}

