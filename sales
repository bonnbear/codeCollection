function findParentAtLevel(tree, childId, level) {
  // 用于存储找到的父节点路径
  const path = [];
  // 递归函数用于遍历树
  function traverse(node, targetId, currentLevel = 0) {
    // 如果找到目标节点,返回true
    if (node.id === targetId) {
      return true;
    }
    // 如果当前节点有子节点,遍历它们
