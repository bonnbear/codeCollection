五、最终 changeYear 最小改动完整版本

/**
 * 年份切换
 *
 * 主要逻辑：
 * 1. 更新 targetYear
 * 2. 重新查询当前用户权限
 * 3. 查询当前年份细分市场树
 * 4. 如果用户权限中有二级及以下细分市场，需要找到它所属的一级父级
 * 5. 最后过滤当前年份可展示的细分市场
 */
const changeYear = (year) => {
  targetYear.value = year + "";
  selectPageWhiteListApi(() => {
    // 当前角色有权限的细分市场 code 列表
    marketSegmentList = curRoleData.value?.marketSegmentList || [];
    // 如果没有任何权限，清空左右两侧树
    if (marketSegmentList.length === 0) {
      dataSource.value.child = [];
      insightTreeDatas.value.child = [];
      return;
    }
    getMarketSegmentData(targetYear.value).then((res) => {
      let parent = [];
      if (levelOther && levelOther.length) {
        levelOther.forEach((ele) => {
          // 用 marketSegmentCode 匹配，而不是 id
          // 因为切换年份后，不同年份的 id 可能不一致
          const item = findParentAtLevel(
            res.data.data[0],
            ele.marketSegmentCode,
            1,
            "marketSegmentCode"
          );
          // findParentAtLevel 可能返回 null，所以必须判断
          if (item && item.marketSegmentCode) {
            parent.push(item.marketSegmentCode);
          } else {
            // 当前年份找不到对应父级时，直接跳过
            console.warn("当前年份未找到该细分市场的一级父节点：", ele);
          }
        });
      }
      // 合并并去重，避免重复追加
      marketSegmentList = [...new Set([...marketSegmentList, ...parent])];
      procMarketSegmentData(res);
    });
  });
};

