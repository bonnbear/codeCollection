} from '@/utils/util';

const {
  locale,
  t,
} = useI18n();

const router = useRouter();

const {
  proxy,
} = getCurrentInstance();

/**
 * 获取路由参数
 */
const projectId = getUrlParam('projectId');
const type = getUrlParam('type');

/**
 * MOR 节点列表
 */
const MOR_NODES = [
  'MOR0',
  'MOR1',
  'MOR2',
  'MOR3',
  'MOR4',
];

/**
 * 版本完整节点顺序
 *
 * 版本行需要展示普通节点和 MOR 节点，
 * 因此这里保留所有节点。
 */
const VERSION_NODE_ORDER = [
  'MOR0',
  'Charter',
  'TR1',
  'CDCP',
  'TR2',
  'MOR1',
  'TR3',
  'PDCP',
  'TR4',
  'TR4A',
  'MOR2',
  'TR5',
  'EDCP',
  'MOR3',
  'TR6',
  'ADCP',
  'GA',
  'MOR4',
];

/**
 * 普通里程碑节点顺序
 *
 * 项目行不展示 MOR，
 * 所以从完整节点中排除 MOR 节点。
 */
const VERSION_NORMAL_NODE_ORDER =
  VERSION_NODE_ORDER.filter(
    (node) => !MOR_NODES.includes(node),
  );

/**
 * 生成随机连接线高度
 *
 * 返回范围为 2～6。
 */
const getRandomConnectorHeight = () => {
  return Math.floor(Math.random() * 5) + 2;
};

/**
 * 项目行连接线随机高度
 *
 * 当前模板中项目行仍然固定使用 6，
 * 这里保留原有变量。
 */
const projectConnectorHeight =
  getRandomConnectorHeight();

/**
 * 保存每个版本对应的连接线高度，
 * 避免 computed 重算时重复生成不同高度。
 */
const versionConnectorHeightMap = new Map();

/**
 * 是否显示返回按钮
 *
 * window.history.state.back 存在时，
 * 说明当前页面存在可返回的上级历史记录。
 */
const hasHistory = computed(() => {
  return Boolean(window.history?.state?.back);
});

/**
 * 返回上一页
 *
 * history.length 大于 1 时，
 * 使用 Vue Router 返回上一条历史记录。
 *
 * 如果没有可用历史记录，
 * 则跳转到首页。
 */
const goBack = () => {
  if (window.history.length > 1) {
    router.back();
  } else {
    router.push('/');
  }
};

/**
 * 页面加载状态
 */
const loading = ref(false);

/**
 * 项目步骤横向滚动容器。
 */
const projectStepsScrollRef = ref(null);

/**
 * 版本步骤横向滚动容器。
 */
const versionStepsScrollRef = ref(null);

/**
 * 横向滚动同步锁。
 *
 * 修改目标容器的 scrollLeft 后，目标容器也会触发 scroll 事件，
 * 使用该标记避免两个容器之间反复触发同步。
 */
let isSyncingHorizontalScroll = false;

/**
 * 按照滚动比例同步两个横向滚动容器。
 *
 * 项目行只包含普通节点，版本行还包含 MOR 节点，
 * 两边内容总宽度可能不同，因此不能简单复制 scrollLeft，
 * 使用滚动比例可以让两边保持一致的相对位置。
 *
 * @param {HTMLElement|null} sourceScroll 当前发生滚动的容器
 * @param {HTMLElement|null} targetScroll 需要同步的目标容器
 */
const syncHorizontalScroll = (
  sourceScroll,
  targetScroll,
) => {
  if (
    !sourceScroll ||
    !targetScroll ||
    isSyncingHorizontalScroll
  ) {
    return;
  }

  const sourceMaxScrollLeft =
    sourceScroll.scrollWidth -
    sourceScroll.clientWidth;

  const targetMaxScrollLeft =
    targetScroll.scrollWidth -
    targetScroll.clientWidth;

  if (sourceMaxScrollLeft <= 0) {
    return;
  }

  const scrollRatio =
    sourceScroll.scrollLeft /
    sourceMaxScrollLeft;

  isSyncingHorizontalScroll = true;

  targetScroll.scrollLeft =
    scrollRatio *
    Math.max(targetMaxScrollLeft, 0);

  requestAnimationFrame(() => {
    isSyncingHorizontalScroll = false;
  });
};

/**
 * 项目步骤区域横向滚动时，同步版本步骤区域。
 */
const handleProjectStepsScroll = () => {
  syncHorizontalScroll(
    projectStepsScrollRef.value,
    versionStepsScrollRef.value,
  );
};

/**
 * 版本步骤区域横向滚动时，同步项目步骤区域。
 */
const handleVersionStepsScroll = () => {
  syncHorizontalScroll(
    versionStepsScrollRef.value,
    projectStepsScrollRef.value,
  );
};

/**
 * 当前登录用户
 */
const currentUser = ref({});

/**
 * 当前项目
 */
const project = ref({});

/**
 * 版本列表
 */
const versions = ref([]);

/**
 * MOR 弹窗是否显示
 */
const dialogVisible = ref(false);

/**
 * 当前点击的版本
 */
const activeVersion = ref(null);

/**
 * 当前点击的 MOR 节点
 */
const activeMorNode = ref('');

/**
 * 当前日期
 *
 * 这里保留原来的固定日期，
 * 用于 mock 或测试计划日期状态。
 */
const today = new Date(
  '2026-07-01T00:00:00+08:00',
);

/**
 * 解析日期
 *
 * @param {string} date 日期字符串
 * @returns {Date|null} 解析后的日期对象
 */
const parseDate = (date) => {
  if (!date) {
    return null;
  }

  const dateText = String(date);

  // 包含 T 时，通常是 ISO 日期格式
  if (dateText.includes('T')) {
    return new Date(dateText);
  }

  // 兼容 yyyy-MM-dd HH:mm:ss 格式
  return new Date(
    dateText.replace(/-/g, '/'),
  );
};

/**
 * 判断指定日期是否早于或等于今天
 *
 * @param {string} date 日期字符串
 * @returns {boolean} 是否已经到达
 */
const isPastOrToday = (date) => {
  if (!date) {
    return false;
  }

  const parsedDate = parseDate(date);

  // 将比较时间设置为今天最后一毫秒
  const endOfToday = new Date(today);

  endOfToday.setHours(
    23,
    59,
    59,
    999,
  );

  return (
    parsedDate instanceof Date &&
    !Number.isNaN(parsedDate.getTime()) &&
    parsedDate <= endOfToday
  );
};

/**
 * 获取里程碑对应的标准节点名称
 *
 * @param {Object} milestone 里程碑对象
 * @returns {string} 节点名称
 */
const getMilestoneNodeKey = (
  milestone = {},
) => {
  // 后端 Charter 节点可能返回 milestoneCharter
  if (
    milestone.milestoneCode ===
    'milestoneCharter'
  ) {
    return 'Charter';
  }

  return (
    milestone.milestoneName ||
    milestone.milestoneCode ||
    milestone.milestoneNameCn ||
    milestone.milestoneNameEn ||
    ''
  );
};

/**
 * 将里程碑数组转换成 Map
 *
 * 一个里程碑可能通过多个字段匹配，
 * 因此将 code、name、中英文名称都作为 key。
 *
 * @param {Array} milestones 里程碑列表
 * @returns {Map} 里程碑映射
 */
const toMilestoneMap = (
  milestones = [],
) => {
  return new Map(
    milestones.flatMap((milestone) => {
      const nodeKey =
        getMilestoneNodeKey(milestone);

      const keys = [
        nodeKey,
        milestone.milestoneCode,
        milestone.milestoneName,
        milestone.milestoneNameCn,
        milestone.milestoneNameEn,
      ].filter(Boolean);

      return keys.map((key) => [
        key,
        {
          ...milestone,
          nodeKey,
        },
      ]);
    }),
  );
};

/**
 * 项目行步骤数据
 *
 * 项目行只展示普通里程碑，
 * 不展示 MOR 节点。
 */
const projectSteps = computed(() => {
  const milestoneMap = toMilestoneMap(
    project.value?.milestones || [],
  );

  return VERSION_NORMAL_NODE_ORDER.map(
    (node, index) => {
      const milestone =
        milestoneMap.get(node);

      const milestoneName =
        milestone?.milestoneName || node;

      const planPublishDate =
        milestone?.planPublishDate || '';

      const arrived =
        milestone?.arrived ??
        isPastOrToday(planPublishDate);

      return {
        ...(milestone || {}),

        id:
          milestone?.id ||
          milestone?.milestoneCode ||
          index,

        nodeKey: node,
        milestoneName,

        subProcessNameCn:
          milestone?.subProcessNameCn,

        subProcessNameEn:
          milestone?.subProcessNameEn,

        planPublishDate,

        arrived,

        state:
          milestone?.state ||
          (arrived
            ? 'Completed'
            : 'NotStarted'),

        perform:
          milestone?.perform ?? false,

        showDivider:
          Boolean(milestone?.showDivider),
      };
    },
  );
});

/**
 * 版本行数据
 *
 * 每个版本展示：
 * 1. 普通里程碑节点
 * 2. MOR 节点
 */
const versionRows = computed(() => {
  return versions.value.map((version) => {
    const milestoneMap = toMilestoneMap(
      version.milestones || [],
    );

    // 同一版本只生成一次随机高度
    const connectorHeight =
      versionConnectorHeightMap.get(
        version.id,
      ) || getRandomConnectorHeight();

    versionConnectorHeightMap.set(
      version.id,
      connectorHeight,
    );

    return {
      ...version,

      connectorHeight,

      steps: VERSION_NODE_ORDER.map(
        (node) => {
          const isMor =
            node.startsWith('MOR');

          const milestone =
            milestoneMap.get(node);

          const milestoneName =
            milestone?.milestoneName ||
            milestone?.milestoneNameCn ||
            milestone?.milestoneNameEn ||
            node;

          const planDate =
            milestone?.planPublishDate || '';

          const milestoneState = isMor
            ? milestone?.milestoneState ||
              'notData'
            : '';

          // MOR 状态为 pending 或 canView 时允许打开
          const canOpenMor = [
            'pending',
            'canView',
          ].includes(milestoneState);

          const arrived =
            milestone?.arrived ??
            (!isMor &&
              isPastOrToday(planDate));

          return {
            ...(milestone || {}),

            id:
              milestone?.id ||
              `${version.id}-${node}`,

            milestoneCode: node,
            nodeKey: node,
            milestoneName,

            milestoneNameCn:
              milestone?.milestoneNameCn ||
              milestoneName,

            milestoneNameEn:
              milestone?.milestoneNameEn ||
              milestoneName,

            subProcessNameCn:
              milestone?.subProcessNameCn,

            subProcessNameEn:
              milestone?.subProcessNameEn,

            // MOR 节点不显示普通计划时间
            planPublishDate: isMor
              ? ''
              : planDate,

            arrived,

            state:
              milestone?.state ||
              (!isMor && arrived
                ? 'Completed'
                : 'NotStarted'),

            perform:
              milestone?.perform ??
              (!isMor && arrived),

            showDivider:
              Boolean(
                milestone?.showDivider,
              ),

            // 是否为 MOR 节点
            isMor,

            // MOR 节点状态
            morState: milestoneState,

            // MOR 是否允许打开
            canOpenMor,

            // 兼容 Step 组件内部字段
            hasMorData: canOpenMor,

            // MOR 是否待当前用户处理
            pendingByMe:
              isMor &&
              milestoneState === 'pending',
          };
        },
      ),
    };
  });
});

/**
 * 打开 MOR 弹窗
 *
 * @param {Object} version 当前版本
 * @param {Object} step 当前点击的步骤节点
 */
const openMorDialog = (
  version,
  step,
) => {
  // 当前 MOR 节点不可打开时结束
  if (!step?.canOpenMor) {
    return;
  }

  /*
   * project 是 ref，
   * 因此 script 中需要通过 project.value 获取值。
   */
  if (!project.value?.permission?.edit) {
    return;
  }

  activeVersion.value = version;
  activeMorNode.value = step.nodeKey;
  dialogVisible.value = true;
};

/**
 * 根据项目 ID 获取项目详情
 *
 * @param {string} id 项目 ID
 * @param {string} projectType 项目类型
 * @returns {Promise<Object|null>} 项目详情
 */
async function fetchProjectByProjectId(
  id,
  projectType,
) {
  try {
    const resp = await proxy.$axios.get(
      '/ugtm/api/v1/ipd/project/details',
      {
        params: {
          projectId: id,
          type: projectType,
        },
      },
    );

    const projectData =
      resp?.data?.data;

    if (!projectData) {
      return null;
    }

    return projectData;
  } catch (error) {
    console.error(
      '获取项目详情失败',
      error,
    );

    return null;
  }
}

/**
 * 获取版本列表
 *
 * @param {string} url 请求地址
 * @returns {Promise<Object|Array|null>} 接口数据
 */
const requestVersionListPage = async (
  url,
) => {
  try {
    const resp =
      await proxy.$axios.get(url);

    const versionListData =
      resp?.data?.data;

    if (!versionListData) {
      return null;
    }

    return versionListData;
  } catch (error) {
    console.error(
      '获取版本列表失败',
      error,
    );

    return null;
  }
};

/**
 * 页面初始化
 */
onMounted(async () => {
  loading.value = true;

  try {
    // URL 未提供参数时，使用默认值
    const currentProjectId =
      projectId || 'PJT-2026-001';

    const currentType =
      type || 'Charter';

    // 并行请求项目详情和版本列表
    const [
      projectDetails,
      versionListResp,
    ] = await Promise.all([
      fetchProjectByProjectId(
        currentProjectId,
        currentType,
      ),

      requestVersionListPage(
        `/ugtm/api/v1/ipd/getMorEditionList?projectId=${currentProjectId}`,
      ),
    ]);

    const payload =
      versionListResp ?? {};

    currentUser.value =
      payload.currentUser ?? {};

    /*
     * 优先使用项目详情接口返回的数据，
     * 以确保包含 lv2HeavyTeamEntity 等信息。
     */
    project.value =
      projectDetails ||
      payload.project ||
      {};

    /*
     * 保留原接口赋值逻辑。
     * 如果接口 data 本身就是数组，可以直接赋值。
     */
    versions.value =
      Array.isArray(payload)
        ? payload
        : payload?.result ||
          payload?.list ||
          payload?.records ||
          [];
  } finally {
    loading.value = false;
  }
});
