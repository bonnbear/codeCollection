{
  "name": "info-manager",
  "version": "1.0.0",
  "description": "資訊管理器",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "electron": "electron main.js",
    "build": "electron-builder"
  },
  "devDependencies": {
    "electron": "^27.0.0",
    "electron-builder": "^24.0.0",
    "nodemon": "^3.0.0"
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "express": "^4.18.2",
    "express-session": "^1.17.3",
    "mongodb": "^7.0.0",
    "papaparse": "^5.5.3",
    "socket.io": "^4.5.4"
  },
  "build": {
    "appId": "com.yourcompany.info-manager",
    "productName": "資訊管理器",
    "directories": {
      "output": "dist"
    },
    "mac": {
      "category": "public.app-category.utilities"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
