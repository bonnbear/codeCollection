#!/usr/bin/env node
"use strict";

const fs = require("fs");
const path = require("path");

const options = parseCliArgs(process.argv.slice(2));

if (!options.inputFile) {
  console.error("用法: node random-const-to-let.js input.json");
  console.error("");
  console.error("input.json 支持：");
  console.error("  1. 数组: [\"src/App.vue\", \"src/Home.vue\"]");
  console.error("  2. 对象: {\"src/App.vue\": true, \"src/Home.vue\": true}");
  console.error("");
  console.error("可选参数:");
  console.error("  --dry-run       只预览，不写入文件");
  console.error("  --backup        写入前生成 .bak 备份");
  console.error("  --rate 0.5      const 改 let 的随机概率，默认 0.5");
  process.exit(1);
}

let inputData;

try {
  inputData = JSON.parse(fs.readFileSync(options.inputFile, "utf8"));
} catch (error) {
  console.error(`[错误] 读取或解析 JSON 失败: ${options.inputFile}`);
  console.error(error.message);
  process.exit(1);
}

const filePaths = normalizeInputFiles(inputData);

if (!filePaths.length) {
  console.error("[错误] 输入 JSON 中没有可处理的 vue 文件路径。");
  console.error("支持对象格式，例如：");
  console.error(JSON.stringify({ "src/App.vue": true }, null, 2));
  console.error("也支持数组格式，例如：");
  console.error(JSON.stringify(["src/App.vue"], null, 2));
  process.exit(1);
}

for (const filePath of filePaths) {
  processVueFile(filePath, options);
}

/**
 * 解析命令行参数
 */
function parseCliArgs(args) {
  const options = {
    inputFile: null,
    dryRun: false,
    backup: false,
    rate: 0.5 // 默认 50% 概率把 const 改成 let
  };

  for (let i = 0; i < args.length; i++) {
    const arg = args[i];

    if (arg === "--dry-run") {
      options.dryRun = true;
      continue;
    }

    if (arg === "--backup") {
      options.backup = true;
      continue;
    }

    if (arg === "--rate") {
      const value = Number(args[i + 1]);

      if (!Number.isFinite(value) || value < 0 || value > 1) {
        console.error("[错误] --rate 必须是 0 到 1 之间的数字，例如 --rate 0.5");
        process.exit(1);
      }

      options.rate = value;
      i++;
      continue;
    }

    if (!options.inputFile) {
      options.inputFile = arg;
      continue;
    }

    console.warn(`[警告] 忽略未知参数: ${arg}`);
  }

  return options;
}

/**
 * 兼容两种输入格式：
 *
 * 1. 数组：
 * [
 *   "src/App.vue",
 *   "src/Home.vue"
 * ]
 *
 * 2. 对象：
 * {
 *   "src/App.vue": true,
 *   "src/Home.vue": true
 * }
 */
function normalizeInputFiles(inputData) {
  if (Array.isArray(inputData)) {
    return inputData
      .map(item => {
        if (typeof item === "string") return item;

        if (item && typeof item === "object") {
          return item.file ?? item.filePath ?? item.path ?? null;
        }

        return null;
      })
      .filter(Boolean)
      .map(String);
  }

  if (inputData && typeof inputData === "object") {
    return Object.keys(inputData).map(String);
  }

  return [];
}

/**
 * 处理单个 Vue 文件
 */
function processVueFile(filePath, options) {
  if (!fs.existsSync(filePath)) {
    console.warn(`[跳过] 文件不存在: ${filePath}`);
    return;
  }

  if (!filePath.endsWith(".vue")) {
    console.warn(`[跳过] 不是 vue 文件: ${filePath}`);
    return;
  }

  const originalContent = fs.readFileSync(filePath, "utf8");

  // 保留原文件换行风格
  const newline = originalContent.includes("\r\n") ? "\r\n" : "\n";

  // 用统一方式拆行，写回时再用原换行符拼回去
  const lines = originalContent.split(/\r?\n/);

  // 找出 Vue SFC 顶层块：template/script/style
  const blocks = detectVueBlocks(lines);

  // 只处理 <script> / <script setup>，并且只处理 JS
  const scriptBlocks = blocks.filter(block => {
    return block.type === "script" && isSupportedScriptBlock(block);
  });

  if (!scriptBlocks.length) {
    console.warn(`[跳过] 没有可处理的 script 块: ${filePath}`);
    return;
  }

  const changes = [];

  for (const block of scriptBlocks) {
    const result = randomlyReplaceConstToLetInScriptBlock(lines, block, options);

    for (const item of result.changes) {
      changes.push(item);
    }
  }

  if (changes.length || options.dryRun) {
    console.log("\n" + "=".repeat(78));
    console.log("SCRIPT const 随机改 let 报告 — " + filePath);
    console.log("=".repeat(78));

    console.log(`\n  随机概率: ${options.rate}`);
    console.log(`  修改数量: ${changes.length}`);
    console.log("  范围: 只处理 <script> / <script setup>");
    console.log("  跳过: template / style / src 外链 script");
    console.log("  避开: 字符串、模板字符串、行注释、块注释");

    if (changes.length) {
      console.log(`\n${"─".repeat(72)}`);
      console.log(`【修改明细】`);
      console.log(`${"─".repeat(72)}`);

      for (const change of changes) {
        console.log(
          `  L${String(change.lineNo).padStart(3)} C${String(change.column).padStart(3)} ✅ const -> let`
        );
      }
    } else {
      console.log("\n没有随机命中的 const，未产生修改。");
    }

    if (options.dryRun) {
      console.log(`\n${"=".repeat(78)}`);
      console.log("预览处理后的文件:");
      console.log("=".repeat(78));
      console.log(lines.join(newline));
    }
  }

  if (!changes.length) {
    return;
  }

  if (options.dryRun) {
    console.log(`\n[预览] ${filePath}，随机修改 ${changes.length} 个 const，未写入`);
    return;
  }

  if (options.backup) {
    const backupPath = `${filePath}.bak`;
    fs.writeFileSync(backupPath, originalContent, "utf8");
    console.log(`[备份] ${backupPath}`);
  }

  fs.writeFileSync(filePath, lines.join(newline), "utf8");
  console.log(`[完成] ${filePath}，随机修改 ${changes.length} 个 const`);
}

/**
 * 随机替换一个 script 块里的 const
 *
 * 核心点：
 * 1. 从 block.startLine 到 block.endLine 扫描
 * 2. 不进入字符串、模板字符串、注释
 * 3. 只识别真正的 const token
 * 4. 命中后按 options.rate 随机替换成 let
 */
function randomlyReplaceConstToLetInScriptBlock(lines, block, options) {
  const changes = [];

  const state = {
    inBlockComment: false, // 是否在 /* xxx */ 块注释中
    inString: null,        // 当前是否在 ' 或 " 字符串中
    inTemplate: false,     // 当前是否在 ` 模板字符串中
    escapeNext: false      // 当前字符是否被反斜杠转义
  };

  for (let lineNo = block.startLine; lineNo <= block.endLine; lineNo++) {
    const line = lines[lineNo - 1];

    const result = replaceConstToLetInLineRandomly(line, state, options.rate);

    if (result.changed) {
      lines[lineNo - 1] = result.line;

      for (const column of result.columns) {
        changes.push({
          lineNo,
          column
        });
      }
    }
  }

  return {
    changes
  };
}

/**
 * 处理单行：
 * 在不破坏注释/字符串状态的前提下，随机把 const 改成 let
 */
function replaceConstToLetInLineRandomly(line, state, rate) {
  let result = "";
  let i = 0;
  let changed = false;
  const columns = [];

  while (i < line.length) {
    const ch = line[i];
    const next = line[i + 1];

    /**
     * 处理转义字符
     *
     * 例如：
     * const str = "hello \"const\"";
     *
     * 这里的 \" 不应该结束字符串
     */
    if (state.escapeNext) {
      result += ch;
      state.escapeNext = false;
      i++;
      continue;
    }

    /**
     * 处理块注释内部
     *
     * 例如：
     * /*
     *   const a = 1;
     * *\/
     *
     * 注释里的 const 不改
     */
    if (state.inBlockComment) {
      if (ch === "*" && next === "/") {
        result += "*/";
        state.inBlockComment = false;
        i += 2;
        continue;
      }

      result += ch;
      i++;
      continue;
    }

    /**
     * 处理普通字符串内部
     *
     * 例如：
     * const text = "const a = 1";
     *
     * 字符串里的 const 不改
     */
    if (state.inString) {
      if (ch === "\\") {
        result += ch;
        state.escapeNext = true;
        i++;
        continue;
      }

      if (ch === state.inString) {
        state.inString = null;
      }

      result += ch;
      i++;
      continue;
    }

    /**
     * 处理模板字符串内部
     *
     * 简化策略：
     * 整个 `...` 里面的 const 都不改。
     *
     * 例如：
     * const text = `const a = 1`;
     *
     * 这里模板字符串里面的不改。
     *
     * 注意：
     * 对于 `${const x = 1}` 这种本身也不是合法 JS；
     * 对于 `${foo ? const : bar}` 也不是正常声明场景。
     * 所以这里统一跳过模板字符串是安全策略。
     */
    if (state.inTemplate) {
      if (ch === "\\") {
        result += ch;
        state.escapeNext = true;
        i++;
        continue;
      }

      if (ch === "`") {
        state.inTemplate = false;
      }

      result += ch;
      i++;
      continue;
    }

    /**
     * 进入行注释后，后面整行不处理
     *
     * 例如：
     * // const a = 1
     */
    if (ch === "/" && next === "/") {
      result += line.slice(i);
      break;
    }

    /**
     * 进入块注释
     *
     * 例如：
     * const a = 1; /* const b = 2 *\/
     */
    if (ch === "/" && next === "*") {
      result += "/*";
      state.inBlockComment = true;
      i += 2;
      continue;
    }

    /**
     * 进入字符串
     */
    if (ch === '"' || ch === "'") {
      state.inString = ch;
      result += ch;
      i++;
      continue;
    }

    /**
     * 进入模板字符串
     */
    if (ch === "`") {
      state.inTemplate = true;
      result += ch;
      i++;
      continue;
    }

    /**
     * 识别真正的 const 关键字
     *
     * 需要满足：
     * 1. 当前从 i 开始是 const
     * 2. const 前面不是变量字符
     * 3. const 后面不是变量字符
     *
     * 避免误伤：
     * constName
     * myconst
     * object.constValue
     */
    if (line.startsWith("const", i)) {
      const before = line[i - 1];
      const after = line[i + 5];

      const beforeOk = !isIdentifierChar(before);
      const afterOk = !isIdentifierChar(after);

      if (beforeOk && afterOk) {
        if (Math.random() < rate) {
          result += "let";
          changed = true;
          columns.push(i + 1); // 列号从 1 开始，方便看报告
        } else {
          result += "const";
        }

        i += 5;
        continue;
      }
    }

    result += ch;
    i++;
  }

  return {
    line: result,
    changed,
    columns
  };
}

/**
 * 判断是否是 JS 标识符字符
 *
 * 用于避免把 constName 里面的 const 改掉。
 */
function isIdentifierChar(ch) {
  if (!ch) return false;
  return /[A-Za-z0-9_$]/.test(ch);
}

/**
 * 检测 Vue 文件中的顶层块
 *
 * 可以识别：
 * <template>
 * <script>
 * <script setup>
 * <style>
 */
function detectVueBlocks(lines) {
  const blocks = [];
  let i = 0;

  while (i < lines.length) {
    const lineForMatch = stripBomAtFirstLine(lines[i], i);

    const openMatch = lineForMatch.match(/^\s*<\s*([A-Za-z][A-Za-z0-9:_-]*)\b/i);

    if (!openMatch) {
      i++;
      continue;
    }

    const type = openMatch[1].toLowerCase();
    const openLine = i + 1;

    const openEnd = findRootOpenTagEnd(lines, i);

    if (!openEnd) {
      blocks.push({
        type,
        lang: null,
        hasSrc: false,
        openLine,
        openEndLine: openLine,
        startLine: openLine + 1,
        endLine: lines.length,
        closeLine: null,
        openTagText: lines[i]
      });

      break;
    }

    const openEndLine = openEnd.index + 1;
    const openTagText = lines.slice(i, openEnd.index + 1).join("\n");

    const lang = normalizeLang(extractAttr(openTagText, "lang"));
    const hasSrc = extractAttr(openTagText, "src") != null;
    const selfClosing = isSelfClosingRootOpenTag(openTagText);

    let closeIndex = null;

    if (selfClosing) {
      closeIndex = openEnd.index;
    } else {
      const closeInfo = findRootCloseTag(lines, type, openEnd.index, openEnd.column);
      closeIndex = closeInfo ? closeInfo.index : null;
    }

    const closeLine = closeIndex != null ? closeIndex + 1 : null;

    /**
     * script 内容范围：
     *
     * <script>
     * const a = 1;
     * </script>
     *
     * startLine 指向 const 那一行
     * endLine 指向 </script> 前一行
     */
    const startLine = openEndLine + 1;
    const endLine = closeIndex != null ? closeIndex : lines.length;

    blocks.push({
      type,
      lang,
      hasSrc,
      openLine,
      openEndLine,
      startLine,
      endLine,
      closeLine,
      openTagText
    });

    if (closeIndex != null) {
      i = closeIndex + 1;
    } else {
      break;
    }
  }

  return blocks;
}

/**
 * 找顶层开始标签的结束位置 >
 *
 * 支持这种多行写法：
 *
 * <script
 *   setup
 *   lang="js"
 * >
 */
function findRootOpenTagEnd(lines, startIndex) {
  let inQuote = null;

  for (let i = startIndex; i < lines.length; i++) {
    const line = lines[i];

    for (let column = 0; column < line.length; column++) {
      const ch = line[column];

      if (inQuote) {
        if (ch === inQuote) {
          inQuote = null;
        }

        continue;
      }

      if (ch === '"' || ch === "'") {
        inQuote = ch;
        continue;
      }

      if (ch === ">") {
        return {
          index: i,
          column
        };
      }
    }
  }

  return null;
}

/**
 * 找顶层关闭标签
 *
 * 例如：
 * </script>
 */
function findRootCloseTag(lines, type, openEndIndex, openEndColumn) {
  const sameLineRest = lines[openEndIndex].slice(openEndColumn + 1);

  const inlineCloseRe = new RegExp(
    `<\\s*\\/\\s*${escapeRegExp(type)}\\s*>`,
    "i"
  );

  if (inlineCloseRe.test(sameLineRest)) {
    return {
      index: openEndIndex
    };
  }

  const closeLineRe = new RegExp(
    `^\\s*<\\s*\\/\\s*${escapeRegExp(type)}\\s*>\\s*$`,
    "i"
  );

  for (let i = openEndIndex + 1; i < lines.length; i++) {
    if (closeLineRe.test(stripBomAtFirstLine(lines[i], i))) {
      return {
        index: i
      };
    }
  }

  return null;
}

/**
 * 判断是否是自闭合顶层标签
 *
 * 例如：
 * <script src="./a.js" />
 */
function isSelfClosingRootOpenTag(openTagText) {
  return /\/\s*>\s*$/.test(openTagText);
}

/**
 * 提取标签属性
 *
 * 支持：
 * lang="js"
 * lang='js'
 * lang=js
 */
function extractAttr(tagText, attrName) {
  const re = new RegExp(
    "\\b" +
      escapeRegExp(attrName) +
      "\\s*=\\s*(?:\"([^\"]*)\"|'([^']*)'|([^\\s\"'=<>`]+))",
    "i"
  );

  const match = tagText.match(re);

  if (!match) return null;

  return match[1] ?? match[2] ?? match[3] ?? null;
}

/**
 * 标准化 lang
 */
function normalizeLang(lang) {
  if (lang == null) return null;
  return String(lang).trim().toLowerCase();
}

/**
 * 是否支持处理这个 script 块
 *
 * 当前只处理：
 * <script>
 * <script setup>
 * <script lang="js">
 * <script lang="javascript">
 *
 * 不处理：
 * <script lang="ts">
 * <script src="./xxx.js">
 */
function isSupportedScriptBlock(block) {
  if (!block) return false;
  if (block.type !== "script") return false;
  if (block.hasSrc) return false;

  return (
    block.lang == null ||
    block.lang === "" ||
    block.lang === "js" ||
    block.lang === "javascript"
  );
}

/**
 * 转义正则特殊字符
 */
function escapeRegExp(value) {
  return String(value).replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
}

/**
 * 去掉文件第一行可能存在的 BOM
 */
function stripBomAtFirstLine(line, index) {
  if (index !== 0) return line;
  return line.replace(/^\uFEFF/, "");
}
