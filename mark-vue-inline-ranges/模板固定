#!/usr/bin/env node
"use strict";

const fs = require("fs");
const crypto = require("crypto");

/**
 * 调试开关
 *
 * 使用方式：
 * DEBUG_MARK=1 node mark-vue-template-tags.js ranges.json --dry-run
 */
const DEBUG = process.env.DEBUG_MARK === "1";

const options = parseCliArgs(process.argv.slice(2));

if (!options.inputFile) {
  console.error("用法: node mark-vue-template-tags.js ranges.json");
  console.error("");
  console.error("input.json 支持：");
  console.error('  1. 数组: ["src/App.vue", "src/Test.vue"]');
  console.error('  2. 对象: {"src/App.vue": [[1, 10]], "src/Test.vue": true}');
  console.error("");
  console.error("可选参数:");
  console.error("  --dry-run    只预览，不写入文件");
  console.error("  --backup     写入前生成 .bak 备份");
  process.exit(1);
}

let inputData;

try {
  inputData = JSON.parse(fs.readFileSync(options.inputFile, "utf8"));
} catch (error) {
  console.error(`[错误] 读取或解析 JSON 失败: ${options.inputFile}`);
  console.error(error.message);
  process.exit(1);
}

const filePaths = normalizeInputFiles(inputData);

if (!filePaths.length) {
  console.error("[错误] 输入 JSON 中没有可处理的 vue 文件路径。");
  console.error("支持对象格式，例如：");
  console.error(JSON.stringify({ "src/App.vue": [[1, 10]] }, null, 2));
  console.error("也支持数组格式，例如：");
  console.error(JSON.stringify(["src/App.vue"], null, 2));
  process.exit(1);
}

for (const filePath of filePaths) {
  processVueFile(filePath, options);
}

/**
 * 解析命令行参数
 */
function parseCliArgs(args) {
  const options = {
    inputFile: null,
    dryRun: false,
    backup: false
  };

  for (let i = 0; i < args.length; i++) {
    const arg = args[i];

    if (arg === "--dry-run") {
      options.dryRun = true;
      continue;
    }

    if (arg === "--backup") {
      options.backup = true;
      continue;
    }

    if (!options.inputFile) {
      options.inputFile = arg;
      continue;
    }

    console.warn(`[警告] 忽略未知参数: ${arg}`);
  }

  return options;
}

/**
 * 兼容两种输入：
 *
 * 1. ["src/App.vue"]
 * 2. { "src/App.vue": [[1, 10]] }
 */
function normalizeInputFiles(inputData) {
  if (Array.isArray(inputData)) {
    return inputData
      .map(item => {
        if (typeof item === "string") return item;

        if (item && typeof item === "object") {
          return item.file ?? item.filePath ?? item.path ?? null;
        }

        return null;
      })
      .filter(Boolean)
      .map(String);
  }

  if (inputData && typeof inputData === "object") {
    return Object.keys(inputData).map(String);
  }

  return [];
}

/**
 * 处理单个 Vue 文件
 */
function processVueFile(filePath, options) {
  if (!fs.existsSync(filePath)) {
    console.warn(`[跳过] 文件不存在: ${filePath}`);
    return;
  }

  if (!filePath.endsWith(".vue")) {
    console.warn(`[跳过] 不是 vue 文件: ${filePath}`);
    return;
  }

  const content = fs.readFileSync(filePath, "utf8");

  // 保留原文件换行符风格
  const newline = content.includes("\r\n") ? "\r\n" : "\n";

  // 内部统一使用 \n 处理，写回时再恢复
  const normalizedContent = content.replace(/\r\n/g, "\n");

  // 按行处理 Vue SFC 根块
  const lines = normalizedContent.split("\n");

  // 找出 template / script / style 等根块
  const blocks = detectVueBlocks(lines);

  if (DEBUG) {
    console.log(`\n[DEBUG] ${filePath} 识别到的 Vue 根块:`);
    for (const block of blocks) {
      console.log("[DEBUG]", block);
    }
  }

  // 这里只处理 template 块
  const templateBlocks = blocks.filter(block => block.type === "template");

  if (!templateBlocks.length) {
    console.warn(`[跳过] 没有 template 块: ${filePath}`);
    return;
  }

  let currentContent = normalizedContent;
  const allReports = [];

  /**
   * 多个 template 块时，从后往前处理。
   *
   * 原因：
   * 字符串插入会改变后续字符索引。
   * 从后往前插入，可以避免前面的修改影响后面的定位。
   */
  const sortedTemplateBlocks = templateBlocks
    .map(block => {
      return {
        ...block,
        startOffset: getOffsetByLineAndColumn(lines, block.startLine, 0),
        endOffset: getOffsetByLineAndColumn(lines, block.endLine + 1, 0)
      };
    })
    .sort((a, b) => b.startOffset - a.startOffset);

  for (const block of sortedTemplateBlocks) {
    const result = addMarkToTemplateBlock({
      content: currentContent,
      originalLines: lines,
      block
    });

    currentContent = result.content;

    for (const report of result.reports) {
      allReports.push(report);
    }
  }

  allReports.sort((a, b) => {
    if (a.lineNo !== b.lineNo) return a.lineNo - b.lineNo;
    return a.column - b.column;
  });

  if (allReports.length || options.dryRun) {
    console.log("\n" + "=".repeat(78));
    console.log("TEMPLATE 标签 data-mark-随机数 插入报告 — " + filePath);
    console.log("=".repeat(78));

    console.log(`\n  插入数量: ${allReports.length}`);
    console.log("  插入形式: data-mark-随机数");
    console.log("  范围: 只处理 <template> 内容，不处理 script/style");
    console.log("  处理:");
    console.log("    - 原生 HTML 标签，例如 div / span / img");
    console.log("    - Vue 组件标签，例如 MyComp / el-button / RouterView");
    console.log("    - 自闭合标签，例如 img / input / MyComp /");
    console.log("    - 多行开始标签");
    console.log("  跳过:");
    console.log("    - <template> 根标签本身");
    console.log("    - 结束标签，例如 </div>");
    console.log("    - HTML 注释");
    console.log("    - DOCTYPE / XML 声明");
    console.log("    - 已经存在 data-mark-数字 的标签");

    if (allReports.length) {
      console.log(`\n${"─".repeat(72)}`);
      console.log(`【TEMPLATE 修改】 (${allReports.length} 个标记属性)`);
      console.log(`${"─".repeat(72)}`);

      for (const report of allReports) {
        console.log(
          `  L${String(report.lineNo).padStart(3)}:${String(report.column).padStart(3)} ✅ <${report.tagName}> → ${report.attrName}`
        );
      }
    } else {
      console.log("\n没有找到可插入位置，未修改 template。");
    }

    if (options.dryRun) {
      console.log(`\n${"=".repeat(78)}`);
      console.log("预览处理后的文件:");
      console.log("=".repeat(78));
      console.log(currentContent);
    }
  }

  if (!allReports.length) {
    return;
  }

  if (options.dryRun) {
    console.log(`\n[预览] ${filePath}，插入 ${allReports.length} 个标记属性，未写入`);
    return;
  }

  if (options.backup) {
    const backupPath = `${filePath}.bak`;
    fs.writeFileSync(backupPath, content, "utf8");
    console.log(`[备份] ${backupPath}`);
  }

  fs.writeFileSync(filePath, currentContent.replace(/\n/g, newline), "utf8");
  console.log(`[完成] ${filePath}，插入 ${allReports.length} 个标记属性`);
}

/**
 * 给单个 template 块里的所有开始标签插入 data-mark-随机数
 */
function addMarkToTemplateBlock({ content, originalLines, block }) {
  const reports = [];

  /**
   * template 内容范围。
   *
   * block.startLine 是 <template> 打开标签结束后的下一行。
   * block.endLine 是 </template> 所在行的前一行。
   */
  const templateStartOffset = getOffsetByLineAndColumn(originalLines, block.startLine, 0);
  const templateEndOffset = getOffsetByLineAndColumn(originalLines, block.endLine + 1, 0);

  const templateContent = content.slice(templateStartOffset, templateEndOffset);

  // 收集 template 内所有可插入的开始标签
  const tagMatches = collectTemplateStartTags(templateContent);

  if (DEBUG) {
    console.log(
      `[DEBUG] template ${block.startLine}-${block.endLine} 识别到可处理开始标签数量:`,
      tagMatches.length
    );
  }

  let newTemplateContent = templateContent;

  /**
   * 从后往前插入属性。
   *
   * 原因：
   * 每次插入都会改变字符串长度。
   * 从后往前处理可以保证前面记录的索引不受影响。
   */
  for (let i = tagMatches.length - 1; i >= 0; i--) {
    const tag = tagMatches[i];

    const absoluteTagStartOffset = templateStartOffset + tag.startOffset;
    const position = getLineAndColumnByOffset(content, absoluteTagStartOffset);

    const random = randomNumber8();

    /**
     * 按你的要求，直接插入一个布尔属性：
     *
     *   data-mark-12345678
     *
     * 不插入：
     *
     *   data-mark-id
     *   data-mark-id="xxx"
     *   data-mark="xxx"
     */
    const attrName = `data-mark-${random}`;
    const attrText = ` ${attrName}`;

    /**
     * 插入点是开始标签的 > 前面。
     *
     * 普通标签：
     *
     *   <div>
     *
     * 变成：
     *
     *   <div data-mark-12345678>
     *
     * 自闭合标签：
     *
     *   <img />
     *
     * 变成：
     *
     *   <img data-mark-12345678 />
     */
    newTemplateContent =
      newTemplateContent.slice(0, tag.insertOffset) +
      attrText +
      newTemplateContent.slice(tag.insertOffset);

    reports.push({
      tagName: tag.tagName,
      lineNo: position.lineNo,
      column: position.column,
      attrName
    });
  }

  const newContent =
    content.slice(0, templateStartOffset) +
    newTemplateContent +
    content.slice(templateEndOffset);

  return {
    content: newContent,
    reports
  };
}

/**
 * 收集 template 内容里的普通开始标签
 *
 * 会识别：
 *
 *   <div>
 *   <div class="a">
 *   <img />
 *   <MyComp />
 *   <el-button>
 *   <component :is="xxx">
 *
 * 会跳过：
 *
 *   </div>
 *   <!-- comment -->
 *   <!DOCTYPE html>
 *   <?xml ?>
 *   已经存在 data-mark-数字 的标签
 */
function collectTemplateStartTags(templateContent) {
  const result = [];

  let i = 0;
  let inComment = false;

  while (i < templateContent.length) {
    const ch = templateContent[i];
    const next = templateContent[i + 1];

    /**
     * 跳过 HTML 注释：
     *
     * <!-- xxx -->
     */
    if (!inComment && templateContent.startsWith("<!--", i)) {
      inComment = true;
      i += 4;
      continue;
    }

    if (inComment) {
      const commentEnd = templateContent.indexOf("-->", i);

      if (commentEnd === -1) {
        break;
      }

      inComment = false;
      i = commentEnd + 3;
      continue;
    }

    if (ch !== "<") {
      i++;
      continue;
    }

    /**
     * 跳过结束标签：
     *
     * </div>
     */
    if (next === "/") {
      i += 2;
      continue;
    }

    /**
     * 跳过声明：
     *
     * <!DOCTYPE html>
     */
    if (next === "!") {
      i += 2;
      continue;
    }

    /**
     * 跳过 XML 声明：
     *
     * <?xml version="1.0" ?>
     */
    if (next === "?") {
      i += 2;
      continue;
    }

    /**
     * 判断标签名。
     *
     * 支持：
     * - div
     * - span
     * - my-comp
     * - el-button
     * - MyComp
     * - RouterView
     * - component
     */
    const tagNameMatch = templateContent
      .slice(i)
      .match(/^<\s*([A-Za-z][A-Za-z0-9:_-]*)\b/);

    if (!tagNameMatch) {
      i++;
      continue;
    }

    const tagName = tagNameMatch[1];

    /**
     * 找到这个开始标签的结束位置。
     *
     * 注意：
     * 标签属性里可能出现：
     *
     *   <div title="a > b">
     *
     * 所以不能简单 indexOf(">")。
     * 必须跳过引号里的 >。
     */
    const tagEnd = findHtmlTagEnd(templateContent, i);

    if (tagEnd == null) {
      if (DEBUG) {
        console.log("[DEBUG] 找到标签开始，但没有找到结束 >，跳过:", tagName);
      }

      i++;
      continue;
    }

    const tagText = templateContent.slice(i, tagEnd + 1);

    /**
     * 已经有 data-mark-随机数 的标签，不重复插入。
     *
     * 例如：
     *
     *   <div data-mark-12345678>
     */
    if (hasAnyDataMarkAttr(tagText)) {
      i = tagEnd + 1;
      continue;
    }

    /**
     * 插入位置默认是 > 前面。
     *
     * 对于自闭合标签：
     *
     *   <img />
     *
     * 不能插成：
     *
     *   <img / data-mark-12345678>
     *
     * 所以如果 > 前面是 /，就插到 / 前面。
     */
    const insertOffset = getTagAttrInsertOffset(templateContent, i, tagEnd);

    result.push({
      tagName,
      startOffset: i,
      endOffset: tagEnd,
      insertOffset
    });

    i = tagEnd + 1;
  }

  return result;
}

/**
 * 计算属性插入位置
 *
 * 普通标签：
 *
 *   <div>
 *       ^
 *       插在 > 前面
 *
 * 自闭合标签：
 *
 *   <img />
 *        ^
 *        插在 / 前面，保证结果是 <img data-mark-12345678 />
 */
function getTagAttrInsertOffset(text, tagStartOffset, tagEndOffset) {
  let i = tagEndOffset - 1;

  // 跳过 > 前面的空白
  while (i > tagStartOffset && /\s/.test(text[i])) {
    i--;
  }

  // 自闭合标签：<img />
  if (text[i] === "/") {
    return i;
  }

  // 普通标签：<div>
  return tagEndOffset;
}

/**
 * 找 HTML 开始标签结束的 >
 *
 * 需要忽略属性值里的 >。
 *
 * 例如：
 *
 *   <div title="1 > 0">
 */
function findHtmlTagEnd(text, startOffset) {
  let inQuote = null;
  let escapeNext = false;

  for (let i = startOffset; i < text.length; i++) {
    const ch = text[i];

    if (escapeNext) {
      escapeNext = false;
      continue;
    }

    if (inQuote) {
      /**
       * Vue 模板里属性可能是：
       *
       *   :title="'a > b'"
       *
       * HTML 属性本身一般不需要反斜杠转义，
       * 但这里保守处理一下，避免误判。
       */
      if (ch === "\\") {
        escapeNext = true;
        continue;
      }

      if (ch === inQuote) {
        inQuote = null;
      }

      continue;
    }

    if (ch === '"' || ch === "'") {
      inQuote = ch;
      continue;
    }

    if (ch === ">") {
      return i;
    }
  }

  return null;
}

/**
 * 判断开始标签里是否已经有 data-mark-随机数 标记
 *
 * 只识别这种：
 *
 *   data-mark-12345678
 *
 * 不会把下面这些当作已标记：
 *
 *   data-mark
 *   data-mark-id
 *   data-mark-id-12345678
 */
function hasAnyDataMarkAttr(tagText) {
  return /(^|[\s"'`<])data-mark-\d+(?=\s|=|\/|>|$)/i.test(tagText);
}

/**
 * 检测 Vue SFC 根块
 *
 * 特点：
 * 1. 不要求 <template> / <script> / <style> 必须在行首
 * 2. 允许根标签出现在一行中间
 * 3. 如果某个块没有正确闭合，不会直接吞掉整个文件
 * 4. 继续向后扫描，尽量识别独立的 template 块
 */
function detectVueBlocks(lines) {
  const blocks = [];

  let i = 0;

  while (i < lines.length) {
    const lineForMatch = stripBomAtFirstLine(lines[i], i);

    const openInfo = findVueRootOpenTagInLine(lineForMatch);

    if (!openInfo) {
      i++;
      continue;
    }

    const type = openInfo.type;
    const openLine = i + 1;
    const openColumn = openInfo.column;

    const openEnd = findRootOpenTagEnd(lines, i, openColumn);

    if (!openEnd) {
      if (DEBUG) {
        console.log(
          `[DEBUG] L${openLine} 找到 <${type}>，但没有找到打开标签结束 >，跳过该行继续扫描`
        );
      }

      i++;
      continue;
    }

    const openEndLine = openEnd.index + 1;
    const openTagText = collectOpenTagText(lines, i, openColumn, openEnd.index, openEnd.column);

    const lang = normalizeLang(extractAttr(openTagText, "lang"));
    const hasSrc = extractAttr(openTagText, "src") != null;
    const selfClosing = isSelfClosingRootOpenTag(openTagText);

    let closeIndex = null;
    let closeColumn = null;

    if (selfClosing) {
      closeIndex = openEnd.index;
      closeColumn = openEnd.column;
    } else {
      const closeInfo = findRootCloseTag(lines, type, openEnd.index, openEnd.column);

      if (closeInfo) {
        closeIndex = closeInfo.index;
        closeColumn = closeInfo.column;
      }
    }

    const closeLine = closeIndex != null ? closeIndex + 1 : null;
    const startLine = openEndLine + 1;
    const endLine = closeIndex != null ? closeIndex : openEndLine;

    blocks.push({
      type,
      lang,
      hasSrc,
      openLine,
      openEndLine,
      startLine,
      endLine,
      closeLine,
      openTagText,
      openColumn,
      closeColumn
    });

    if (DEBUG) {
      console.log(
        `[DEBUG] 识别根块 <${type}>`,
        {
          openLine,
          openEndLine,
          startLine,
          endLine,
          closeLine,
          openColumn,
          closeColumn,
          lang,
          hasSrc
        }
      );
    }

    if (closeIndex != null) {
      i = closeIndex + 1;
    } else {
      i = openEnd.index + 1;
    }
  }

  return blocks;
}

/**
 * 在一行中查找 Vue SFC 根块打开标签
 */
function findVueRootOpenTagInLine(line) {
  const text = String(line);
  const re = /<\s*([A-Za-z][A-Za-z0-9:_-]*)\b/g;

  let match;

  while ((match = re.exec(text))) {
    const column = match.index;
    const type = match[1].toLowerCase();

    if (/^<\s*\//.test(text.slice(column))) {
      continue;
    }

    if (isInsideHtmlCommentOnSameLine(text, column)) {
      continue;
    }

    if (!isVueSfcBlockType(type)) {
      continue;
    }

    return {
      type,
      column
    };
  }

  return null;
}

/**
 * Vue SFC 根块类型
 */
function isVueSfcBlockType(type) {
  return (
    type === "template" ||
    type === "script" ||
    type === "style" ||
    type === "i18n" ||
    type === "docs" ||
    type === "route"
  );
}

/**
 * 判断某个位置是否在同一行的 HTML 注释中
 */
function isInsideHtmlCommentOnSameLine(line, column) {
  const before = line.slice(0, column);

  const lastCommentOpen = before.lastIndexOf("<!--");
  const lastCommentClose = before.lastIndexOf("-->");

  return lastCommentOpen !== -1 && lastCommentOpen > lastCommentClose;
}

/**
 * 找根标签打开结束的 >
 */
function findRootOpenTagEnd(lines, startIndex, startColumn = 0) {
  let inQuote = null;

  for (let i = startIndex; i < lines.length; i++) {
    const line = lines[i];
    const fromColumn = i === startIndex ? startColumn : 0;

    for (let column = fromColumn; column < line.length; column++) {
      const ch = line[column];

      if (inQuote) {
        if (ch === inQuote) inQuote = null;
        continue;
      }

      if (ch === '"' || ch === "'") {
        inQuote = ch;
        continue;
      }

      if (ch === ">") {
        return { index: i, column };
      }
    }
  }

  return null;
}

/**
 * 收集打开标签文本
 */
function collectOpenTagText(lines, startIndex, startColumn, endIndex, endColumn) {
  // 如果打开标签在同一行，直接截取这一行的对应内容
  if (startIndex === endIndex) {
    return lines[startIndex].slice(startColumn, endColumn + 1);
  }

  const parts = []; // 用来收集多行打开标签的每一段内容

  for (let i = startIndex; i <= endIndex; i++) {
    // 第一行：从开始列截取到行尾
    if (i === startIndex) {
      parts.push(lines[i].slice(startColumn));
      continue;
    }

    // 最后一行：从行首截取到结束列
    if (i === endIndex) {
      parts.push(lines[i].slice(0, endColumn + 1));
      continue;
    }

    // 中间行：整行加入
    parts.push(lines[i]);
  }

  // 多行内容重新用 \n 拼回去
  return parts.join("\n");
}

/**
 * 找根标签关闭行
 */
function findRootCloseTag(lines, type, openEndIndex, openEndColumn) {
  const closeRe = new RegExp(`<\\s*\\/\\s*${escapeRegExp(type)}\\s*>`, "ig");

  for (let i = openEndIndex; i < lines.length; i++) {
    const line = lines[i];
    const searchStart = i === openEndIndex ? openEndColumn + 1 : 0;

    closeRe.lastIndex = searchStart;

    const match = closeRe.exec(line);

    if (match) {
      if (isInsideHtmlCommentOnSameLine(line, match.index)) {
        continue;
      }

      return {
        index: i,
        column: match.index
      };
    }
  }

  return null;
}

/**
 * 判断根标签是否自闭合
 */
function isSelfClosingRootOpenTag(openTagText) {
  return /\/\s*>\s*$/.test(openTagText);
}

/**
 * 提取标签属性
 */
function extractAttr(tagText, attrName) {
  const re = new RegExp(
    "\\b" +
      escapeRegExp(attrName) +
      "\\s*=\\s*(?:\"([^\"]*)\"|'([^']*)'|([^\\s\"'=<>`]+))",
    "i"
  );

  const match = tagText.match(re);

  if (!match) return null;

  return match[1] ?? match[2] ?? match[3] ?? null;
}

/**
 * 规范化 lang
 */
function normalizeLang(lang) {
  if (lang == null) return null;
  return String(lang).trim().toLowerCase();
}

/**
 * 根据行号和列号计算字符串偏移量
 *
 * lineNo 从 1 开始。
 * column 从 0 开始。
 */
function getOffsetByLineAndColumn(lines, lineNo, column) {
  let offset = 0;

  const targetLineIndex = Math.max(0, lineNo - 1);

  for (let i = 0; i < targetLineIndex && i < lines.length; i++) {
    // +1 是因为内部统一换行符是 \n
    offset += lines[i].length + 1;
  }

  return offset + column;
}

/**
 * 根据字符串偏移量反推行号和列号
 *
 * lineNo 从 1 开始。
 * column 从 1 开始，方便报告查看。
 */
function getLineAndColumnByOffset(content, offset) {
  let lineNo = 1;
  let lineStartOffset = 0;

  for (let i = 0; i < offset; i++) {
    if (content[i] === "\n") {
      lineNo++;
      lineStartOffset = i + 1;
    }
  }

  return {
    lineNo,
    column: offset - lineStartOffset + 1
  };
}

/**
 * 生成 8 位随机数
 */
function randomNumber8() {
  return crypto.randomInt(10000000, 100000000);
}

/**
 * 正则转义
 */
function escapeRegExp(value) {
  return String(value).replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
}

/**
 * 去掉第一行 BOM
 */
function stripBomAtFirstLine(line, index) {
  if (index !== 0) return line;
  return line.replace(/^\uFEFF/, "");
}