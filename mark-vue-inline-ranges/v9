    const beforeState = cloneStyleScanState(state);

    scanStyleLineForInsertionState(line, state);

    if (lineNo < bucketStart || lineNo > bucketEnd) continue;

    if (usedAnchors.has(`${block.openLine}:replaceLine:${lineNo}`)) continue;
    if (usedAnchors.has(`${block.openLine}:insertAfter:${lineNo}`)) continue;

