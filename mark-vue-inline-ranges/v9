    if (escapeNext) {
      escapeNext = false;
      i++;
      continue;
    }

    if (inString) {
      if (ch === "\\") {
        escapeNext = true;
        i++;
        continue;
      }

      if (ch === inString) {
        inString = null;
      }

      i++;
      continue;
    }

    if (inBlockComment) {
      if (ch === "*" && next === "/") {
        inBlockComment = false;
        i += 2;
        continue;
      }

      i++;
      continue;
    }

    if (interpolationDepth > 0) {
