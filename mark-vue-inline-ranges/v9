    if (ch === "#" && next === "{") {
      interpolationDepth = 1;
      i += 2;
      continue;
    }

    if (ch === "/" && next === "*") {
      inBlockComment = true;
      i += 2;
      continue;
    }

    if (ch === '"' || ch === "'") {
      inString = ch;
      i++;
      continue;
    }

    if (ch === "(") {
      parenDepth++;
      segment += ch;
      i++;
      continue;
    }

    if (ch === ")") {
      parenDepth = Math.max(0, parenDepth - 1);
      segment += ch;
      i++;
      continue;
